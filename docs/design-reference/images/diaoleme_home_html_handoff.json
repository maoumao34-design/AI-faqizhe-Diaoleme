{
  "project": "掉了么（Diaoleme）现有首页视觉精修与还原度提升",
  "version": "1.1",
  "language": "zh-CN",
  "task_definition": {
    "task_type": "visual_fidelity_refinement",
    "primary_goal": "基于参考图的视觉规范修正现有 HTML 设计，提高视觉还原度、完整度和整体完成度。",
    "not_a_rebuild": true,
    "existing_implementation_is_baseline": true,
    "implementation_rules": [
      "优先保留现有 HTML 结构、功能、路由和技术栈",
      "先检查现有实现，再修改 CSS、布局参数和视觉素材",
      "仅在参考图无法通过现有 DOM 准确还原时，才进行最小范围的结构调整",
      "不得另起一套页面、重新设计信息架构或重复实现已有功能",
      "每轮修改后在固定视口截图，并与参考图叠加对比后继续微调"
    ]
  },
  "objective": {
    "goal": "在现有首页 HTML 基础上进行视觉修正，使其尽可能接近参考效果图，而不是新建或重做一个 HTML 页面。",
    "source_of_truth": "Hero.jpg",
    "asset_source": "Home.png",
    "critical_rule": "图1决定现有页面需要被修正成什么样；图2只提供可裁切的视觉素材。禁止把任务理解为新建页面或按素材板重新设计。"
  },
