{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://diaoleme.demo/schemas/hair-analysis-response.schema.json",
  "title": "HairAnalysisResponse",
  "description": "Canonical response for POST /api/analyze and POST /api/hair-analysis.",
  "type": "object",
  "required": [
    "success",
    "fallbackCode",
    "record_id",
    "analysisId",
    "record_status",
    "image_url",
    "ai_source",
    "result"
  ],
  "properties": {
    "success": { "type": "boolean" },
    "fallbackCode": { "type": ["string", "null"] },
    "record_id": { "type": "string", "pattern": "^rec_" },
    "analysisId": { "type": "string", "pattern": "^ana_" },
    "record_status": { "type": "string", "minLength": 1 },
    "image_url": { "type": ["string", "null"] },
    "ai_source": {
      "type": "string",
      "enum": ["openai_compatible", "siliconflow", "mock", "fallback"]
    },
    "error": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "result": {
      "type": "object",
      "required": [
        "score",
        "title",
        "summary",
        "task",
        "growthDelta",
        "tags",
        "disclaimer",
        "roast",
        "encouragement",
        "image_quality",
        "source",
        "source_label",
        "daily_task",
        "count",
        "thickness",
        "suggestions"
      ],
      "properties": {
        "score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "task": {
          "type": "object",
          "required": ["name", "description", "exp_reward"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "description": { "type": "string", "minLength": 1 },
            "exp_reward": { "type": "integer", "minimum": 0 }
          }
        },
        "growthDelta": {
          "type": "object",
          "required": ["exp_added", "current_level", "streak_days"],
          "properties": {
            "exp_added": { "type": "integer", "minimum": 0 },
            "current_level": { "type": "integer", "minimum": 1 },
            "streak_days": { "type": "integer", "minimum": 0 }
          }
        },
        "tags": {
          "type": "array",
          "maxItems": 4,
          "items": { "type": "string", "minLength": 1 }
        },
        "disclaimer": {
          "type": "string",
          "const": "本结果仅用于娱乐和习惯记录，不构成医疗建议。"
        },
        "roast": { "type": "string", "minLength": 1 },
        "encouragement": { "type": "string", "minLength": 1 },
        "image_quality": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "enum": ["api", "mock", "fallback"] },
        "source_label": { "type": "string", "minLength": 1 },
        "daily_task": { "type": "string", "minLength": 1 },
        "count": { "type": "string", "enum": ["少量", "中等", "偏多"] },
        "thickness": { "type": "string", "enum": ["粗硬", "正常", "细软"] },
        "suggestions": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
