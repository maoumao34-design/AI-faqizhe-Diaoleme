# Copy to platform Environment Variables UI — do NOT commit real secrets.

# Required by platform (usually auto-set)
PORT=8787
NODE_ENV=production

# AI provider: openai_compatible | siliconflow
# Demo can run without keys (mock / fallback). Real AI needs one key below.
AI_PROVIDER=siliconflow

# SiliconFlow (default when AI_PROVIDER=siliconflow)
SILICONFLOW_API_KEY=
SILICONFLOW_MODEL=Qwen/Qwen3-VL-32B-Instruct
SILICONFLOW_TIMEOUT_MS=90000

# OpenAI-compatible Responses API (when AI_PROVIDER=openai_compatible)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_MS=90000

# Optional JSON records path (ephemeral on free PaaS)
# RECORDS_FILE=data/records.json
